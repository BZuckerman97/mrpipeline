library(dplyr)
library(data.table)
library(TwoSampleMR)
library(coloc)
#' SET UP
Q_VAL_TRHESH <- 1e-5
OUTC_PHENO <- "SjD"
#' MHC region
MHC_CHR <- 6
MHC_WINDOW_MIN <- 26000000
MHC_WINDOW_MAX <- 34000000
#' Exposure
#' eSNP file
plasma_sc <- fread("plasma_esnp_table.tsv")
plasma_sc_eqtl <- fread("plasma_eqtl_table.tsv")
#' Outcome
sjd <- fread("outcome_snps.tsv")
#' Format exposure (Plasma cell as an example)
#' Remove MHC region
plasma_sc_format <- plasma_sc |>
filter(!(CHR == MHC_CHR & POS >= MHC_WINDOW_MIN & POS <= MHC_WINDOW_MAX)) |>
#' Filter Q-value
filter(Q_VALUE < 1e-5)
plasma_sc_format <- plasma_sc_format |>
mutate(
SNP = RSID,
se            = abs(SPEARMANS_RHO / qnorm(P_VALUE/2)),
beta          = SPEARMANS_RHO,
pval          = P_VALUE,
cell          = CELL_TYPE,
phenotype     = GENE,
effect_allele = A2,
) %>%
select(cell, phenotype, SNP, effect_allele, beta, se, pval)
#' Format plasma_sc_format
exposure_format <- format_data(
as.data.frame(plasma_sc_format),
type = "exposure",
snp_col           = "SNP",
beta_col          = "beta",
se_col            = "se",
effect_allele_col = "effect_allele",
phenotype_col     = "phenotype",
pval_col          = "pval"
)
#' Outcome
#' Make sure it is a data frame
outcome <- as.data.frame(sjd)
#' Create ID
outcome <- outcome |>
mutate(phenotype = OUTC_PHENO)
#' Format outcome
outcome_format <- format_data(
outcome,
type = "outcome",
phenotype_col = "phenotype",
snp_col = "SNP",
beta_col = "beta",
se_col = "se",
effect_allele = "effect_allele",
other_allele = "other_allele",
pval_col = "pval"
)
#' Harmonise
har <- harmonise_data(exposure_format, outcome_format, action = 1)
#' Run scMR
mr_res <- mr(har) |>
filter(method %in% c("Inverse variance weighted", "Wald ratio")) |>
mutate(qval = p.adjust(pval, method = "BH"))
View(mr_res)
#' Harmonise
har <- harmonise_data(exposure_format, outcome_format)
mr_res <- mr(har) |>
filter(method %in% c("Inverse variance weighted", "Wald ratio")) |>
mutate(qval = p.adjust(pval, method = "BH"))
View(har)
plasma_sc_format <- plasma_sc_format |>
mutate(
